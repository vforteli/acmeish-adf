{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "acmeish-dev-adf"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://acmeishdevsa.dfs.core.windows.net/"
		},
		"acmeish_dev_kv_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://acmeish-dev-kv.vault.azure.net/"
		},
		"eventtrigger_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/ed5190ab-ab51-4f01-8a86-4825c1d7f284/resourceGroups/acme-adftest-rg/providers/Microsoft.Storage/storageAccounts/acmeishdevsa"
		},
		"repeish_acme_out_properties_repeish_copy_and_archive_file_parameters_source_file_name": {
			"type": "string",
			"defaultValue": "@triggerBody().fileName"
		},
		"repeish_acme_out_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/ed5190ab-ab51-4f01-8a86-4825c1d7f284/resourceGroups/acme-adftest-rg/providers/Microsoft.Storage/storageAccounts/acmeishdevsa"
		},
		"default_properties_kv_url_value": {
			"type": "string",
			"defaultValue": "https://acmeish-dev-kv.vault.azure.net/"
		},
		"default_properties_env_name_value": {
			"type": "string",
			"defaultValue": "dev"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "acmeish-dev-adf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"default_properties_kv_url_value": {
						"value": "[parameters('default_properties_kv_url_value')]"
					},
					"default_properties_env_name_value": {
						"value": "[parameters('default_properties_env_name_value')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"acmeish_dev_kv_properties_typeProperties_baseUrl": {
						"value": "[parameters('acmeish_dev_kv_properties_typeProperties_baseUrl')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "acmeish-dev-adf_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"eventtrigger_properties_typeProperties_scope": {
						"value": "[parameters('eventtrigger_properties_typeProperties_scope')]"
					},
					"repeish_acme_out_properties_repeish_copy_and_archive_file_parameters_source_file_name": {
						"value": "[parameters('repeish_acme_out_properties_repeish_copy_and_archive_file_parameters_source_file_name')]"
					},
					"repeish_acme_out_properties_typeProperties_scope": {
						"value": "[parameters('repeish_acme_out_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'acmeish-dev-adf_ArmTemplate_0')]"
			]
		}
	]
}