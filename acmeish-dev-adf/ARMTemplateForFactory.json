					"type": "LinkedServiceReference"
				},
				"folder": {
					"name": "repeish/acme"
				},
				"annotations": [],
				"type": "Binary",
				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
						"folderPath": "in/acme",
						"fileSystem": "repeish"
					}
				}
			},
			"dependsOn": [
