								]
							}
						],
						"policy": {
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"variableName": "foo",
							"value": "bar"
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"variables": {
					"foo": {
						"type": "String"
					}
				},
				"annotations": []
			},
			"dependsOn": []
		},
