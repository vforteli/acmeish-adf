						"type": "string"
					}
				},
				"folder": {
					"name": "repeish/acme"
				},
				"annotations": [],
				"type": "Binary",
				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
						"fileName": {
							"value": "@dataset().file_path",
							"type": "Expression"
						},
						"folderPath": "out/acme_archive",
						"fileSystem": "repeish"
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/AzureDataLakeStorage1')]"
